{$R *.dfm}

procedure TDrawLetterF.DrawLetterButtonClick(Sender: TObject);
var
 aWord:string;
begin


  aWord := Copy(Edit1.Text,1,1);
  if aWord='' then exit;

  DownLoad(aWord);


end;

procedure TDrawLetterF.FormClose(Sender: TObject; var Action: TCloseAction);
begin
  Action := cafree;
end;

procedure TDrawLetterF.FormCreate(Sender: TObject);
begin
  MediaSuite.Startup;
  MediaEngine := CreateMediaEngineEx(Self.Handle);
  MediaEngine.OnEvent := MediaEngineEvent;
  TrackBarVolume.Position := Round(TrackBarVolume.Max * MediaEngine.Volume);
  TrackBarBalance.Position := Round(TrackBarBalance.Max * MediaEngine.Balance);
  CheckBoxMute.Checked := MediaEngine.Muted;
end;

procedure TDrawLetterF.FormShow(Sender: TObject);
begin
  Edit1.SetFocus;
end;

procedure TDrawLetterF.MediaEngineEvent(Sender: TObject;
  EventType: TMediaEngineEventType);
 function ToSeconds(Value: Double): string;
  begin
    Result := FormatFloat('0.0000', Value)
  end;

  procedure UpdateTime;
  var Duration, CurrentTime: Double;
  begin
    Duration := MediaEngine.Duration;
    CurrentTime := MediaEngine.CurrentTime;

    if IsNan(Duration) then
    begin
      LabelPosition.Caption := '';
      TrackBarPosition.Position := 0;
    end
    else
    begin
      LabelPosition.Caption := ToSeconds(CurrentTime) + ' : ' + ToSeconds(Duration);
      TrackBarPosition.Position := Round(TrackBarPosition.Max * CurrentTime / Duration);
    end;
  end;
begin
  case EventType of
    eeCanPlay:
    begin
      {$ifdef D2009PLUS}
      TrackBarPosition.Enabled := True;
      {$endif D2009PLUS}
      ButtonOpen.Enabled := True;
      ButtonPlay.Enabled := True;
      ButtonPause.Enabled := False;
      ButtonStep.Enabled := MediaEngine.Video;
      ButtonStop.Enabled := False;
      TrackBarVolume.Enabled := MediaEngine.Audio;
      TrackBarBalance.Enabled := MediaEngine.Audio;
      CheckBoxMute.Enabled := MediaEngine.Audio;
      CheckBoxMirror.Enabled := MediaEngine.Video;
      UpdateTime;
    end;

  //  eeFirstFrameReady:
     // PanelVideo.Visible := MediaEngine.Video;

    eePlaying:
    begin
      ButtonOpen.Enabled := False;
      ButtonPlay.Enabled := False;
      ButtonPause.Enabled := True;
      ButtonStep.Enabled := MediaEngine.Video;
      ButtonStop.Enabled := True;
    end;

    eePause, eeEnded:
    begin
      ButtonOpen.Enabled := True;
      ButtonPlay.Enabled := True;
      ButtonPause.Enabled := False;
      ButtonStep.Enabled := MediaEngine.Video;
      ButtonStop.Enabled := True;
      UpdateTime;

      if (EventType= eeEnded) then begin
          MediaEngine.OnEvent := nil;
          MediaEngine.CurrentTime := 0;
          MediaEngine.Pause;
          MediaEngine.OnEvent := MediaEngineEvent;
      end;
    end;

    eeTimeUpdated:
      UpdateTime;
  end;

end;

procedure TDrawLetterF.ProcessEvent(EventType: TMediaEngineEventType);
begin

end;

procedure TDrawLetterF.RunTimerTimer(Sender: TObject);
begin
  RunTimer.Enabled := false;
  DrawLetterButton.Click;
end;

procedure TDrawLetterF.Timer1Timer(Sender: TObject);
begin
 if ButtonPlay.Enabled then begin
    if (Timer1.Tag = 1) then Timer1.Enabled := false;
    MediaEngine.Pause;
    ButtonPlay.Click;
    Timer1.Tag := Timer1.Tag +1;
 end;


end;

procedure TDrawLetterF.TrackBarVolumeChange(Sender: TObject);
begin
    MediaEngine.Volume := TrackBarVolume.Position / 10.0;
end;

procedure TDrawLetterF.ButtonPauseClick(Sender: TObject);
begin
 MediaEngine.Pause;
 MediaEngine.CurrentTime := 0;
end;

procedure TDrawLetterF.ButtonPlayClick(Sender: TObject);
begin
  MediaEngine.Play;
end;

procedure TDrawLetterF.ButtonStopClick(Sender: TObject);
begin
  MediaEngine.Pause;

end;

procedure TDrawLetterF.CheckBoxMuteClick(Sender: TObject);
begin
  MediaEngine.Muted := CheckBoxMute.Checked;
end;

procedure TDrawLetterF.DownLoad(mWord:string);
var
  CharValue: Char;
  UnicodeCode,URL,StrokeCode: String;
begin
  Timer1.Enabled := false;
  MediaEngine.Pause;
  MediaEngine.CurrentTime := 0;
  Timer1.Enabled := false;
  MediaEngine.Pause;
  StrokeCode := GetStrokeCode(mWord);
  if StrokeCode='' then   exit;


  CharValue := mWord[1];
  UnicodeCode := Format('%4.4X', [Ord(CharValue)]);  // 將 Unicode 編碼轉為十六進制
  URL := 'https://www.twpen.com/bishun-animation/'+ Lowercase(UnicodeCode) + '-stroke-order.gif';
           Down_Gif.URL := URL;
           Down_Gif.LocalFile := '1.gif';
           Down_Gif.UserName := '';
           Down_Gif.Password := '';
           Down_Gif.ThreadCount := 2;
           Down_Gif.Start(True);

  URL := 'https://stroke-order.learningweb.moe.edu.tw/sound/'+StrokeCode  +'.mp3';

   // PanelVideo.Visible := False;

    TrackBarPosition.Enabled := False;
    TrackBarPosition.Position := 0;
    ButtonPlay.Enabled := False;
    ButtonPause.Enabled := False;
    ButtonStep.Enabled := False;
    ButtonStop.Enabled := False;
    LabelPosition.Caption := '0.0000 : 0.0000';
    MediaEngine.Source := URL;



end;

procedure TDrawLetterF.Down_GifProcessCompleted(Sender: TObject);
begin
   Image1.Picture.LoadFromFile(Down_Gif.LocalFile);
   (Image1.Picture.Graphic as TGIFImage).Animate := true;
   Timer1.Tag := 0;
   Timer1.Enabled := true;

end;



